  "keyFeatures": [
    "Nonlinear branching dialogue with conditions and mutations",
    "Integrated dialogue editor with syntax highlighting",
    "Stateless runtime for easy state management",
    "Custom DialogueLabel node with BBCode support",
    "Full C# support via wrapper classes",
    "Built-in translation support",
    "Customizable dialogue balloons",
    "Random line selection and weighting",
    "Label/jump system for dialogue flow control",
    "Concurrent/simultaneous dialogue lines"
  ],
